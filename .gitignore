# ── Private documents (drafts, write-ups, presentations) ──────────────────────
*.docx
*.doc
*.pptx
*.ppt
*.xlsx
*.xls

# ── Internal docs (brand guide, site structure, progress tracking) ────────────
_private/

# ── Private projects (not for public release) ────────────────────────────────
# Ignore everything in blue-owl/, except the public companion folder for the post.
blue-owl/*
!blue-owl/Regulating Private Credit/

# ── Per-folder drafts (use _drafts/ or _draft prefix inside any research folder)
_drafts/
_draft*

# ── Python / Jupyter ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
.ipynb_checkpoints/

# ── Chart outputs (regenerate from notebooks) ─────────────────────────────────
outputs/
*.png

# OS / editor configs are handled by the global excludes file
# (see git config --global core.excludesfile)
